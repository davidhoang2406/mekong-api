{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Real-time and historical market data for Vietnamese stocks and crypto.",
        "title": "Mekong Market Data API",
        "contact": {},
        "version": "1.0"
    },
    "host": "app.mekong.local",
    "basePath": "/api/v1",
    "paths": {
        "/digest": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "digest"
                ],
                "summary": "Daily market digest (top gainers/losers/volume)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Date YYYY-MM-DD (default: today, falls back to latest)",
                        "name": "date",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter category: gainer, loser, volume",
                        "name": "category",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Max results per category (default: 10)",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.DigestResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/digest/live": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "digest"
                ],
                "summary": "Live intraday digest computed from WS snapshot cache",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter: gainer, loser, volume",
                        "name": "category",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Max results per category (default: 10)",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Service health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/indicators": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "market-data"
                ],
                "summary": "Technical indicators for a symbol",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Symbol",
                        "name": "symbol",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Start date YYYY-MM-DD",
                        "name": "from",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "End date YYYY-MM-DD",
                        "name": "to",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.IndicatorsResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/ohlcv": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "market-data"
                ],
                "summary": "OHLCV bars for a symbol",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Symbol (e.g. VCB, BTC-USDT)",
                        "name": "symbol",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Start date YYYY-MM-DD (default: 30 days ago)",
                        "name": "from",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "End date YYYY-MM-DD (default: today)",
                        "name": "to",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.OHLCVResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/screener": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "market-data"
                ],
                "summary": "Weekly fundamental screener",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Year (default: current)",
                        "name": "year",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "ISO week number (default: current)",
                        "name": "week",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.ScreenerResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/snapshot": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "live"
                ],
                "summary": "Latest live price snapshot for a symbol",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Symbol (e.g. BTC-USDT)",
                        "name": "symbol",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.PriceSnapshot"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "502": {
                        "description": "Bad Gateway",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/symbols": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "market-data"
                ],
                "summary": "List available symbols",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter by asset class (stock, crypto)",
                        "name": "asset_class",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.SymbolsResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "model.DigestEntry": {
            "type": "object",
            "properties": {
                "asset_class": {
                    "type": "string"
                },
                "category": {
                    "type": "string"
                },
                "close": {
                    "type": "number"
                },
                "exchange": {
                    "type": "string"
                },
                "open": {
                    "type": "number"
                },
                "pct_change": {
                    "type": "number"
                },
                "rank": {
                    "type": "integer"
                },
                "symbol": {
                    "type": "string"
                },
                "volume": {
                    "type": "integer"
                }
            }
        },
        "model.DigestResponse": {
            "type": "object",
            "properties": {
                "date": {
                    "type": "string"
                },
                "digest": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.DigestEntry"
                    }
                }
            }
        },
        "model.IndicatorRow": {
            "type": "object",
            "properties": {
                "bb_lower": {
                    "type": "number"
                },
                "bb_mid": {
                    "type": "number"
                },
                "bb_upper": {
                    "type": "number"
                },
                "close": {
                    "type": "number"
                },
                "macd": {
                    "type": "number"
                },
                "macd_hist": {
                    "type": "number"
                },
                "macd_signal": {
                    "type": "number"
                },
                "rsi14": {
                    "type": "number"
                },
                "sma20": {
                    "type": "number"
                },
                "sma200": {
                    "type": "number"
                },
                "sma50": {
                    "type": "number"
                },
                "time": {
                    "type": "string"
                }
            }
        },
        "model.IndicatorsResponse": {
            "type": "object",
            "properties": {
                "indicators": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.IndicatorRow"
                    }
                },
                "symbol": {
                    "type": "string"
                }
            }
        },
        "model.OHLCVBar": {
            "type": "object",
            "properties": {
                "close": {
                    "type": "number"
                },
                "high": {
                    "type": "number"
                },
                "low": {
                    "type": "number"
                },
                "open": {
                    "type": "number"
                },
                "time": {
                    "type": "string"
                },
                "volume": {
                    "type": "integer"
                }
            }
        },
        "model.OHLCVResponse": {
            "type": "object",
            "properties": {
                "asset_class": {
                    "type": "string"
                },
                "bars": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.OHLCVBar"
                    }
                },
                "exchange": {
                    "type": "string"
                },
                "symbol": {
                    "type": "string"
                }
            }
        },
        "model.PriceSnapshot": {
            "type": "object",
            "properties": {
                "ask": {
                    "type": "number"
                },
                "asset_class": {
                    "type": "string"
                },
                "bid": {
                    "type": "number"
                },
                "change": {
                    "type": "number"
                },
                "exchange": {
                    "type": "string"
                },
                "pct_change": {
                    "type": "number"
                },
                "price": {
                    "type": "number"
                },
                "symbol": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string"
                },
                "volume": {
                    "type": "integer"
                }
            }
        },
        "model.ScreenerResponse": {
            "type": "object",
            "properties": {
                "results": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.ScreenerResult"
                    }
                },
                "week": {
                    "type": "string"
                },
                "year": {
                    "type": "string"
                }
            }
        },
        "model.ScreenerResult": {
            "type": "object",
            "properties": {
                "current_ratio": {
                    "type": "number"
                },
                "de_ratio": {
                    "type": "number"
                },
                "eps": {
                    "type": "number"
                },
                "pb_ratio": {
                    "type": "number"
                },
                "pe_ratio": {
                    "type": "number"
                },
                "roe": {
                    "type": "number"
                },
                "symbol": {
                    "type": "string"
                }
            }
        },
        "model.SymbolInfo": {
            "type": "object",
            "properties": {
                "asset_class": {
                    "type": "string"
                },
                "exchange": {
                    "type": "string"
                },
                "first_date": {
                    "type": "string"
                },
                "last_date": {
                    "type": "string"
                },
                "symbol": {
                    "type": "string"
                }
            }
        },
        "model.SymbolsResponse": {
            "type": "object",
            "properties": {
                "symbols": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.SymbolInfo"
                    }
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "JWT token — prefix value with \"Bearer \"",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}